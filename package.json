{
  "name": "anion",
  "version": "0.1.0",
  "license": "MIT OR Apache-2.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,api,worker \"pnpm dev:web\" \"pnpm dev:api\" \"pnpm dev:worker\"",
    "dev:web": "node ./scripts/run-workspace.mjs web dev",
    "dev:api": "node ./scripts/run-workspace.mjs api dev",
    "dev:worker": "node ./scripts/run-workspace.mjs worker dev",
    "build": "pnpm check:ports && pnpm exec tsc --noEmit && pnpm --filter @anion/web build",
    "start": "node ./scripts/run-workspace.mjs web start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "cross-env PORT_BASE=3100 node ./scripts/playwright/anion-flow.mjs",
    "playwright:install": "playwright install chromium",
    "playwright:flow": "node ./scripts/playwright/anion-flow.mjs",
    "playwright:flow:headed": "node ./scripts/playwright/anion-flow.mjs --headed",
    "check:ports": "node ./scripts/check-ports.mjs"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0"
  }
}
