{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": ["./apps/web/*"],
      "@anion/application": ["./packages/application/src/index.ts"],
      "@anion/config": ["./packages/config/src/index.ts"],
      "@anion/contracts": ["./packages/contracts/src/index.ts"],
      "@anion/infrastructure": ["./packages/infrastructure/src/index.ts"],
      "@anion/shared": ["./packages/shared/src/index.ts"],
      "@anion/shared/command-artifacts": ["./packages/shared/src/command-artifacts.ts"],
      "@anion/shared/utils": ["./packages/shared/src/utils.ts"],
      "@anion/shared/visuals/renderers": ["./packages/shared/src/visuals/renderers.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
